<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Inventario</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <a href="/" class="navbar-brand">📊 <span>Contabilidad</span></a>
            <div class="nav-links">
                <a href="/inventario">📦 Inventario</a>
                <a href="/ventas">💰 Ventas</a>
                <a href="/contabilidad">📊 Contabilidad</a>
                <a href="/facturas">🧾 Facturas</a>
                <a href="/cuentas-por-cobrar">💳 Cuentas por Cobrar</a>
                <a href="/configuracion">⚙️ Configuración</a>
            </div>
        </nav>
    </header>

    <div class="container">
        <!-- BADGE DE MODO PRUEBA -->
        <% if (modoPrueba || (datos && datos.modo_prueba_activo)) { %>
            <div class="alert alert-warning">⚠️ MODO PRUEBA ACTIVO - Los cambios no se guardan</div>
        <% } %>

        <div class="card">
            <div class="card-header">
                <h1 class="card-title">📊 Sistema de Inventario y Contabilidad</h1>
            </div>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin: 1.5rem 0;">
                <div style="background: #e8f0fe; padding: 1.5rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 2.5rem;">📦</div>
                    <div style="font-size: 1.8rem; font-weight: 700; color: #1a2a6c;"><%= Object.keys(datos.productos).length %></div>
                    <div style="color: #666;">Productos</div>
                </div>
                <div style="background: #e6f7ed; padding: 1.5rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 2.5rem;">🧾</div>
                    <div style="font-size: 1.8rem; font-weight: 700; color: #11998e;"><%= datos.facturas.length %></div>
                    <div style="color: #666;">Facturas</div>
                </div>
                <div style="background: #fef3e2; padding: 1.5rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 2.5rem;">💰</div>
                    <div style="font-size: 1.8rem; font-weight: 700; color: #f7971e;"><%= datos.libro_diario.length %></div>
                    <div style="color: #666;">Transacciones</div>
                </div>
                <div style="background: #fce4ec; padding: 1.5rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 2.5rem;">💳</div>
                    <div style="font-size: 1.8rem; font-weight: 700; color: #e74c3c;"><%= datos.facturas.filter(f => f.saldo_pendiente > 0).length %></div>
                    <div style="color: #666;">Cuentas por Cobrar</div>
                </div>
            </div>

            <div class="btn-group" style="justify-content: center; margin-top: 1rem; flex-wrap: wrap;">
                <a href="/inventario" class="btn btn-primary">📦 Ver Inventario</a>
                <a href="/ventas" class="btn btn-success">💰 Nueva Venta</a>
                <a href="/facturas" class="btn btn-warning">🧾 Facturas</a>
                <a href="/cuentas-por-cobrar" class="btn btn-danger">💳 Cuentas por Cobrar</a>
                <a href="/configuracion" class="btn btn-outline">⚙️ Configuración</a>
            </div>
        </div>
    </div>

    <footer>
        <p>Sistema de Contabilidad Dual v5.0 &bull; Node.js &bull; <%= new Date().getFullYear() %></p>
    </footer>
</body>
</html>
