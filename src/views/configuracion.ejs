<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .config-section {
            margin-bottom: 2rem;
        }
        .config-section .section-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: #1a2a6c;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #f0f2f5;
        }
        .backup-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: center;
        }
        .backup-actions .btn {
            padding: 0.7rem 1.8rem;
        }
        .file-input-wrapper {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            flex-wrap: wrap;
            background: #f8f9fa;
            padding: 0.5rem 1rem;
            border-radius: 10px;
            border: 2px dashed #ddd;
        }
        .file-input-wrapper input[type="file"] {
            padding: 0.5rem;
            border: none;
            background: white;
            border-radius: 8px;
            font-size: 0.9rem;
        }
        .file-input-wrapper input[type="file"]:hover {
            cursor: pointer;
        }
        .warning-box {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 0.8rem 1.2rem;
            border-radius: 8px;
            margin-top: 1rem;
            font-size: 0.9rem;
            color: #856404;
        }
        .info-box {
            background: #e8f0fe;
            border-left: 4px solid #1a2a6c;
            padding: 0.8rem 1.2rem;
            border-radius: 8px;
            margin-top: 0.5rem;
            font-size: 0.9rem;
            color: #1a2a6c;
        }
        .flash-message {
            padding: 1rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            font-weight: 500;
        }
        .flash-success {
            background: #d4edda;
            color: #155724;
            border-left: 4px solid #28a745;
        }
        .flash-error {
            background: #f8d7da;
            color: #721c24;
            border-left: 4px solid #dc3545;
        }
        .flash-warning {
            background: #fff3cd;
            color: #856404;
            border-left: 4px solid #ffc107;
        }
        @media (max-width: 600px) {
            .backup-actions {
                flex-direction: column;
                align-items: stretch;
            }
            .file-input-wrapper {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar">
            <a href="/" class="navbar-brand">📊 <span>Contabilidad</span></a>
            <div class="nav-links">
                <a href="/inventario">📦 Inventario</a>
                <a href="/ventas">💰 Ventas</a>
                <a href="/contabilidad" class="active">📊 Contabilidad</a>
                <a href="/facturas">🧾 Facturas</a>
            </div>
        </nav>
    </header>

    <div class="container">
        <!-- Mostrar mensajes flash si existen -->
        <% if (flash && flash.message) { %>
            <div class="flash-message flash-<%= flash.type || 'success' %>">
                <%= flash.message %>
            </div>
        <% } %>

        <div class="card">
            <div class="card-header">
                <h2 class="card-title">⚙️ Configuración</h2>
                <a href="/" class="btn btn-outline">⬅ Volver</a>
            </div>

            <!-- Sección: Copia de Seguridad -->
            <div class="config-section">
                <div class="section-title">📁 Copia de Seguridad</div>
                
                <p style="color: #666; margin-bottom: 1.2rem;">
                    Exporta todos tus datos (productos, clientes, facturas, transacciones, etc.) a un archivo Excel, o importa desde un archivo Excel para restaurar toda la información.
                </p>

                <div class="backup-actions">
                    <!-- Botón Exportar -->
                    <a href="/api/backup/exportar-excel" class="btn btn-success">
                        📤 Exportar a Excel
                    </a>

                    <!-- Formulario Importar -->
                    <form action="/api/backup/importar-excel" method="post" enctype="multipart/form-data" style="display: inline;">
                        <div class="file-input-wrapper">
                            <input type="file" name="archivo" accept=".xlsx,.xls" required>
                            <button type="submit" class="btn btn-warning">
                                📥 Importar desde Excel
                            </button>
                        </div>
                    </form>
                </div>

                <div class="warning-box">
                    ⚠️ <strong>Importante:</strong> Al importar desde Excel, se <strong>sobrescribirán TODOS</strong> los datos actuales (productos, clientes, facturas, etc.). Asegúrate de tener una copia de seguridad previa.
                </div>

                <div class="info-box">
                    💡 El archivo Excel exportado contiene <strong>6 hojas</strong>: 
                    Productos, Clientes, Proveedores, Facturas, Libro Diario, Tasas y Configuración de Empresa.
                </div>
            </div>

            <hr style="margin: 2rem 0; border: none; border-top: 2px solid #f0f2f5;">

            <!-- Sección: Backup JSON (interno) -->
            <div class="config-section">
                <div class="section-title">💾 Backup Interno (JSON)</div>
                <p style="color: #666; margin-bottom: 1.2rem;">
                    Crea o restaura una copia de seguridad en formato JSON (archivo interno del sistema).
                </p>
                <div class="backup-actions">
                    <button onclick="crearBackupJSON()" class="btn btn-primary">
                        💾 Crear Backup JSON
                    </button>
                    <button onclick="restaurarBackupJSON()" class="btn btn-danger">
                        🔄 Restaurar Backup JSON
                    </button>
                </div>
                <div id="backupMessage" style="margin-top: 1rem;"></div>
                <div class="warning-box" style="margin-top: 0.8rem;">
                    ⚠️ El backup JSON guarda los datos en el servidor (archivo <code>data/datos_backup.json</code>). 
                    Restaurar sobrescribirá los datos actuales.
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>Sistema de Contabilidad Dual v5.0 &bull; Node.js</p>
    </footer>

    <script>
        // Función para crear backup JSON mediante fetch
        async function crearBackupJSON() {
            const msg = document.getElementById('backupMessage');
            msg.innerHTML = '<div class="flash-message flash-warning">⏳ Creando backup...</div>';
            try {
                const res = await fetch('/api/backup/crear', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    msg.innerHTML = `<div class="flash-message flash-success">✅ ${data.message}</div>`;
                } else {
                    msg.innerHTML = `<div class="flash-message flash-error">❌ ${data.error}</div>`;
                }
            } catch (error) {
                msg.innerHTML = `<div class="flash-message flash-error">❌ Error: ${error.message}</div>`;
            }
        }

        // Función para restaurar backup JSON
        async function restaurarBackupJSON() {
            if (!confirm('⚠️ ¿Estás seguro de restaurar el backup JSON? Se perderán los cambios actuales.')) return;
            const msg = document.getElementById('backupMessage');
            msg.innerHTML = '<div class="flash-message flash-warning">⏳ Restaurando backup...</div>';
            try {
                const res = await fetch('/api/backup/restaurar', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    msg.innerHTML = `<div class="flash-message flash-success">✅ ${data.message}</div>`;
                    setTimeout(() => location.reload(), 1500);
                } else {
                    msg.innerHTML = `<div class="flash-message flash-error">❌ ${data.error}</div>`;
                }
            } catch (error) {
                msg.innerHTML = `<div class="flash-message flash-error">❌ Error: ${error.message}</div>`;
            }
        }
    </script>
</body>
</html>
