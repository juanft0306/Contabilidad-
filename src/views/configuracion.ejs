<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <a href="/" class="navbar-brand">📊 <span>Contabilidad</span></a>
            <div class="nav-links">
                <a href="/inventario">📦 Inventario</a>
                <a href="/ventas">💰 Ventas</a>
                <a href="/contabilidad">📊 Contabilidad</a>
                <a href="/facturas">🧾 Facturas</a>
                <a href="/configuracion" class="active">⚙️ Configuración</a>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">⚙️ Configuración</h2>
                <a href="/" class="btn btn-outline">⬅ Volver</a>
            </div>

            <!-- Sección: Copia de Seguridad -->
            <div style="margin: 2rem 0;">
                <h3 style="color: #1a2a6c; margin-bottom: 1rem;">📁 Copia de Seguridad</h3>
                <p style="color: #666; margin-bottom: 1.2rem;">
                    Exporta todos tus datos a un archivo Excel, o importa desde un archivo Excel para restaurar la información.
                </p>

                <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
                    <a href="/api/backup/exportar-excel" class="btn btn-success">
                        📤 Exportar a Excel
                    </a>

                    <form action="/api/backup/importar-excel" method="post" enctype="multipart/form-data" style="display: inline;">
                        <div style="display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; background: #f8f9fa; padding: 0.5rem 1rem; border-radius: 10px; border: 2px dashed #ddd;">
                            <input type="file" name="archivo" accept=".xlsx,.xls" required style="padding: 0.5rem; border: none; background: white; border-radius: 8px;">
                            <button type="submit" class="btn btn-warning">
                                📥 Importar desde Excel
                            </button>
                        </div>
                    </form>
                </div>

                <div style="background: #fff3cd; border-left: 4px solid #ffc107; padding: 0.8rem 1.2rem; border-radius: 8px; margin-top: 1rem; font-size: 0.9rem; color: #856404;">
                    ⚠️ <strong>Importante:</strong> Al importar desde Excel, se <strong>sobrescribirán TODOS</strong> los datos actuales.
                </div>
            </div>

            <hr style="margin: 2rem 0; border: none; border-top: 2px solid #f0f2f5;">

            <!-- Sección: Backup JSON -->
            <div style="margin: 2rem 0;">
                <h3 style="color: #1a2a6c; margin-bottom: 1rem;">💾 Backup Interno (JSON)</h3>
                <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
                    <button onclick="crearBackupJSON()" class="btn btn-primary">
                        💾 Crear Backup JSON
                    </button>
                    <button onclick="restaurarBackupJSON()" class="btn btn-danger">
                        🔄 Restaurar Backup JSON
                    </button>
                </div>
                <div id="backupMessage" style="margin-top: 1rem;"></div>
            </div>
        </div>
    </div>

    <footer>
        <p>Sistema de Contabilidad Dual v5.0 &bull; Node.js</p>
    </footer>

    <script>
        async function crearBackupJSON() {
            const msg = document.getElementById('backupMessage');
            msg.innerHTML = '<div style="background: #fff3cd; padding: 0.8rem; border-radius: 8px;">⏳ Creando backup...</div>';
            try {
                const res = await fetch('/api/backup/crear', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    msg.innerHTML = `<div style="background: #d4edda; padding: 0.8rem; border-radius: 8px; color: #155724;">✅ ${data.message}</div>`;
                } else {
                    msg.innerHTML = `<div style="background: #f8d7da; padding: 0.8rem; border-radius: 8px; color: #721c24;">❌ ${data.error}</div>`;
                }
            } catch (error) {
                msg.innerHTML = `<div style="background: #f8d7da; padding: 0.8rem; border-radius: 8px; color: #721c24;">❌ Error: ${error.message}</div>`;
            }
        }

        async function restaurarBackupJSON() {
            if (!confirm('⚠️ ¿Estás seguro de restaurar el backup JSON? Se perderán los cambios actuales.')) return;
            const msg = document.getElementById('backupMessage');
            msg.innerHTML = '<div style="background: #fff3cd; padding: 0.8rem; border-radius: 8px;">⏳ Restaurando backup...</div>';
            try {
                const res = await fetch('/api/backup/restaurar', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    msg.innerHTML = `<div style="background: #d4edda; padding: 0.8rem; border-radius: 8px; color: #155724;">✅ ${data.message}</div>`;
                    setTimeout(() => location.reload(), 1500);
                } else {
                    msg.innerHTML = `<div style="background: #f8d7da; padding: 0.8rem; border-radius: 8px; color: #721c24;">❌ ${data.error}</div>`;
                }
            } catch (error) {
                msg.innerHTML = `<div style="background: #f8d7da; padding: 0.8rem; border-radius: 8px; color: #721c24;">❌ Error: ${error.message}</div>`;
            }
        }
    </script>
</body>
</html>
